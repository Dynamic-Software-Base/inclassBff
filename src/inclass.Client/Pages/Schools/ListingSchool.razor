@page "/ListingSchool"
@page "/schools"
@using Contract.InClass.Request.School
@using Contract.InClass.Response.School
@using Contract.InClass.Pagination
@using inclass.Client.Components.School
@using inclass.Client.Services
@inject SchoolService SchoolService

<div class="min-h-screen bg-gray-50">
    
    <div class="bg-white border-b border-gray-200 px-6 py-8">
        <div class="max-w-7xl mx-auto">
            <h1 class="text-2xl font-bold text-gray-900 tracking-tight">Find a School</h1>
            <p class="text-sm text-gray-500 mt-1">
                Discover schools across Morocco that match your needs
            </p>

            <div class="mt-5">
                <SearchSchoolComponent OnSearch="HandleSearch" />
            </div>
        </div>
    </div>
    
    <div class="max-w-7xl mx-auto px-6 py-6">
        
        <div class="flex items-center justify-between mb-4">
            @if (_result is not null)
            {
                <p class="text-sm text-gray-500">
                    <span class="font-semibold text-gray-800">@_result.TotalCount</span> schools found
                </p>
            }
            else if (_loading)
            {
                <p class="text-sm text-gray-400">Searching...</p>
            }
        </div>
        
        <div class="flex gap-5 items-start">
            
            <div class="flex-1 min-w-0">

                @if (_loading && _schools.Count == 0)
                {
                    <div class="flex flex-col gap-2">
                        @for (int i = 0; i < 5; i++)
                        {
                            <div class="bg-white rounded-xl p-4 flex gap-4 animate-pulse border border-gray-100">
                                <div class="w-16 h-16 rounded-xl bg-gray-200 shrink-0"></div>
                                <div class="flex-1 flex flex-col gap-2 justify-center">
                                    <div class="h-3.5 bg-gray-200 rounded w-2/3"></div>
                                    <div class="h-2.5 bg-gray-100 rounded w-1/3"></div>
                                    <div class="flex gap-1 mt-1">
                                        <div class="h-4 w-12 bg-gray-100 rounded-md"></div>
                                        <div class="h-4 w-14 bg-gray-100 rounded-md"></div>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                }
                else if (!_loading && _schools.Count == 0)
                {
                    <div class="flex flex-col items-center justify-center py-16 text-center bg-white rounded-2xl border border-gray-100">
                        <div class="w-14 h-14 rounded-2xl bg-gray-100 flex items-center justify-center mb-4">
                            <svg class="w-7 h-7 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
                                      d="M21 21l-4.35-4.35M17 11A6 6 0 1 1 5 11a6 6 0 0 1 12 0z"/>
                            </svg>
                        </div>
                        <p class="text-sm font-medium text-gray-700">No schools found</p>
                        <p class="text-xs text-gray-400 mt-1">Try adjusting your filters</p>
                    </div>
                }
                else
                {
                    <div class="flex flex-col gap-2">

                        @foreach (var school in _schools)
                        {
                            <SchoolCardPublic School="school"
                                        IsSelected="@(_selected?.SchoolId == school.SchoolId)"
                                        OnSelect="SelectSchool" />
                        }
                        
                        @if (_result?.HasNextPage == true)
                        {
                            <div class="pt-2 pb-1 flex justify-center">
                                @if (_loadingMore)
                                {
                                    <div class="flex items-center gap-2 text-sm text-gray-400 py-3">
                                        <svg class="w-4 h-4 animate-spin" fill="none" viewBox="0 0 24 24">
                                            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/>
                                            <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8v8z"/>
                                        </svg>
                                        Loading more...
                                    </div>
                                }
                                else
                                {
                                    <button
                                        class="flex items-center gap-2 text-sm text-indigo-600 hover:text-indigo-700 font-medium py-3 px-5 rounded-xl hover:bg-indigo-50 transition-colors border border-indigo-100"
                                        @onclick="LoadMore">
                                        Show more schools
                                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
                                        </svg>
                                    </button>
                                }
                            </div>
                        }
                    </div>
                }
            </div>
            
            <div class="w-80 xl:w-96 shrink-0">
                <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-4">
                    <SchoolDetailWidget School="_selected" />
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private GetSchoolQuery  _activeQuery  = new(null, null, null);
    private PagedResult<SchoolSummaryDto>? _result;
    private List<SchoolSummaryDto>         _schools      = [];
    private SchoolSummaryDto?              _selected;
    private int                            _currentPage  = 1;
    private bool                           _loading;
    private bool                           _loadingMore;

    protected override async Task OnInitializedAsync() =>
        await FetchPage(1, replace: true);

    private async Task HandleSearch(GetSchoolQuery query)
    {
        _activeQuery = query;
        _schools.Clear();
        _selected = null;
        await FetchPage(1, replace: true);
    }

    private async Task LoadMore()
    {
        if (_result?.HasNextPage != true || _loadingMore) return;
        _loadingMore = true;
        await FetchPage(_currentPage + 1, replace: false);
        _loadingMore = false;
    }

    private async Task FetchPage(int page, bool replace)
    {
        _loading = replace;
        StateHasChanged();

        var queryWithPage = _activeQuery; // page/size handled by service or query record
        var response = await SchoolService.GetSchools(queryWithPage);

        if (response.IsSuccess && response.Data is not null)
        {
            _result      = response.Data;
            _currentPage = page;

            if (replace)
            {
                _schools = _result.Items.ToList();
                // Auto-select first
                _selected = _schools.FirstOrDefault();
            }
            else
            {
                _schools.AddRange(_result.Items);
            }
        }

        _loading = false;
    }

    private void SelectSchool(SchoolSummaryDto school) => _selected = school;
}
