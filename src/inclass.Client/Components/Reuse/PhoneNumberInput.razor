@* PhoneNumberInput.razor *@
<div>
    <label for="@Id" class="block text-sm font-medium text-gray-700 mb-1">
        @Label
        @if (Required)
        {
            <span class="text-red-500">*</span>
        }
    </label>
    <div class="relative">
        <div class="absolute inset-y-0 inset-s-0 flex items-center ps-3 pointer-events-none">
            <svg class="w-4 h-4 text-gray-500" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" viewBox="0 0 24 24">
                <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18.427 14.768 17.2 13.542a1.733 1.733 0 0 0-2.45 0l-.613.613a1.732 1.732 0 0 1-2.45 0l-1.838-1.84a1.735 1.735 0 0 1 0-2.452l.612-.613a1.735 1.735 0 0 0 0-2.452L9.237 5.572a1.6 1.6 0 0 0-2.45 0c-3.223 3.2-1.702 6.896 1.519 10.117 3.22 3.221 6.914 4.745 10.12 1.535a1.601 1.601 0 0 0 0-2.456Z"/>
            </svg>
        </div>
        <input 
            type="tel" 
            id="@Id" 
            @bind="@CurrentValue"
            @oninput="HandleInput"
            maxlength="10"
            class="block w-full ps-9 pe-3 py-2 border border-gray-300 text-gray-900 text-sm rounded-md focus:ring-indigo-500 focus:border-indigo-500 shadow-sm placeholder:text-gray-400 @GetValidationClass()"
            placeholder="@Placeholder">
    </div>
    @if (!string.IsNullOrEmpty(ValidationMessage))
    {
        <p class="text-red-600 text-sm mt-1">@ValidationMessage</p>
    }
</div>

@code {
    [Parameter]
    public string Id { get; set; } = Guid.NewGuid().ToString();

    [Parameter]
    public string Label { get; set; } = "Phone Number";

    [Parameter]
    public string? Value { get; set; }

    [Parameter]
    public EventCallback<string?> ValueChanged { get; set; }

    [Parameter]
    public bool Required { get; set; }

    [Parameter]
    public string Placeholder { get; set; } = "06XXXXXXXX";

   

    private string? currentValue;
    private string? validationMessage;

    private string? CurrentValue
    {
        get => currentValue;
        set
        {
            if (currentValue != value)
            {
                currentValue = value;
                ValidatePhoneNumber(value);
                ValueChanged.InvokeAsync(value);
            }
        }
    }

    private string? ValidationMessage
    {
        get => validationMessage;
        set => validationMessage = value;
    }

    protected override void OnParametersSet()
    {
        currentValue = Value;
    }

    private void HandleInput(ChangeEventArgs e)
    {
        var input = e.Value?.ToString() ?? string.Empty;
        
        // Only allow digits
        var digitsOnly = new string(input.Where(char.IsDigit).ToArray());
        
        // Limit to 10 digits
        if (digitsOnly.Length > 10)
        {
            digitsOnly = digitsOnly.Substring(0, 10);
        }

        CurrentValue = digitsOnly;
    }

    private void ValidatePhoneNumber(string? number)
    {
        if (string.IsNullOrWhiteSpace(number))
        {
            ValidationMessage = Required ? "Phone number is required" : null;
            return;
        }

        // Check if all characters are digits
        if (!number.All(char.IsDigit))
        {
            ValidationMessage = "Phone number must contain only digits";
            return;
        }

        // Check length
        if (number.Length != 10)
        {
            ValidationMessage = "Phone number must be exactly 10 digits";
            return;
        }

        // Check if starts with valid prefix
        if (!number.StartsWith("06") && !number.StartsWith("07") && !number.StartsWith("05"))
        {
            ValidationMessage = "Phone number must start with 05, 06, or 07";
            return;
        }

        ValidationMessage = null;
    }

    private string GetValidationClass()
    {
        if (string.IsNullOrEmpty(currentValue))
        {
            return string.Empty;
        }

        return string.IsNullOrEmpty(validationMessage) 
            ? "border-green-500 focus:ring-green-500 focus:border-green-500" 
            : "border-red-500 focus:ring-red-500 focus:border-red-500";
    }
}
