@* Components/Schools/GradeLevelTag.razor *@
<span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg text-xs font-medium bg-indigo-50 text-indigo-700 border border-indigo-100">
    <span>@Icon</span>
    @Label
</span>

@code {
    [Parameter, EditorRequired] public string Label { get; set; } = "";
    [Parameter]                 public string Icon  { get; set; } = "";
}