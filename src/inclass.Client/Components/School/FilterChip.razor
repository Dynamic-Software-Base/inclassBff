@* Components/Schools/FilterChip.razor *@

<span class="inline-flex items-center gap-1.5 bg-indigo-50 text-indigo-700 text-xs font-medium px-3 py-1.5 rounded-full border border-indigo-100">
    @Label
    <button @onclick="OnRemove"
            class="w-3.5 h-3.5 rounded-full flex items-center justify-center hover:bg-indigo-200 transition-colors">
        <svg fill="none" stroke="currentColor" viewBox="0 0 24 24" class="w-2.5 h-2.5">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M6 18L18 6M6 6l12 12"/>
        </svg>
    </button>
</span>

@code {
    [Parameter, EditorRequired] public string Label { get; set; } = "";
    [Parameter, EditorRequired] public EventCallback OnRemove { get; set; }
}